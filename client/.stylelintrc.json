{
  "extends": "stylelint-config-standard",
  "ignoreFiles": [
    ".angular", 
    ".offline", 
    "dist/**", 
    "**/dist/**", 
    "node_modules/**",
    "**/node_modules/**"
  ],
  "overrides": [
    {
      "files": ["**/*.scss"],
      "customSyntax": "postcss-scss",
      "rules": {
        "at-rule-no-unknown": [
          true,
          {
            "ignoreAtRules": [
              "use",
              "mixin",
              "include",
              "extend",
              "function",
              "return",
              "each",
              "for",
              "if",
              "else",
              "while"
            ]
          }
        ]
      }
    }
  ],
  "rules": {
    "alpha-value-notation": ["percentage", { "exceptProperties": [] }],
    "color-function-notation": "modern",
    "media-feature-range-notation": "context",
    "selector-class-pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*(?:__(?:[a-z0-9]+(?:-[a-z0-9]+)*))?(?:--(?:[a-z0-9]+(?:-[a-z0-9]+)*))?$"
  }
}
