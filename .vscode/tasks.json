{
  // See https://go.microsoft.com/fwlink/?LinkId=733558
  // Schema: https://code.visualstudio.com/docs/reference/tasks-appendix
  "$schema": "vscode://schemas/tasks",
  "version": "2.0.0",
  "presentation": {
    "clear": true,
    "panel": "dedicated",
    "showReuseMessage": false
  },
  "problemMatcher": [],
  "options": {
    "cwd": "${workspaceFolder}"
  },
  "tasks": [
    {
      "label": "Setup: Dev environment (linux)",
      "detail": "Install all development prerequisites (Node, .NET, Azure Functions Core Tools, pnpm)",
      "type": "shell",
      "command": "bash scripts/setup-linux.sh",
      "group": "none"
    },
    {
      "label": "Initialize: Pull, rebuild, and verify",
      "detail": "Pull latest, clean, rebuild, format, lint, and run tests",
      "dependsOn": [
        "Git: pull",
        "Build: All projects (full rebuild)",
        "Lint: All (fix)",
        "Test: All tests"
      ],
      "dependsOrder": "sequence",
      "group": "build",
      "problemMatcher": ["$tsc", "$msCompile", "$markdownlint"]
    },
    {
      "label": "Git: pull",
      "detail": "Pull latest changes from Git",
      "type": "shell",
      "command": "git pull || echo 'No remote branch'"
    },
    {
      "label": "Install: All package dependencies",
      "detail": "Restore NuGet and Node.js packages across workspaces",
      "dependsOn": ["Install: Packages (NuGet)", "Install: Packages (pnpm)"],
      "dependsOrder": "parallel"
    },
    {
      "label": "Install: Packages (pnpm)",
      "detail": "Restore Node.js packages across workspaces",
      "type": "shell",
      "command": "pnpm install"
    },
    {
      "label": "Install: Packages (NuGet)",
      "detail": "Restore .NET packages for solution",
      "type": "shell",
      "command": "dotnet restore Charts.sln",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Check: Node packages",
      "detail": "Check for dependency updates in root and all workspace packages",
      "type": "shell",
      "command": "pnpm run deps:check"
    },
    {
      "label": "Check: Angular packages (client)",
      "detail": "Check for dependency updates using Angular CLI for the client website.",
      "type": "shell",
      "command": "pnpm --filter @stock-charts/client exec ng update"
    },
    {
      "label": "Update: Angular packages (client)",
      "detail": "Update dependencies using Angular CLI for the client website.",
      "type": "shell",
      "command": "pnpm --filter @stock-charts/client exec ng update @angular/cli @angular/core @angular/material angular-eslint --allow-dirty"
    },
    {
      "label": "Update: Node packages",
      "detail": "Update dependencies in root and all workspace packages to latest versions",
      "type": "shell",
      "command": "pnpm run deps:update && pnpm install",
      "dependsOn": "Update: Angular packages (client)",
      "dependsOrder": "sequence"
    },
    {
      "label": "Build: All projects (incremental)",
      "detail": "Incremental build of Website and Backend .NET",
      "dependsOn": ["Build: Backend .NET (incremental)", "Build: Website"],
      "dependsOrder": "parallel",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$tsc", "$msCompile"]
    },
    {
      "label": "Build: All projects (full rebuild)",
      "detail": "Full hard-reset rebuild without incremental compilation",
      "dependsOn": [
        "Clean: All (hard reset)",
        "Install: All package dependencies",
        "Build: Backend .NET (non-incremental)",
        "Build: Website"
      ],
      "dependsOrder": "sequence",
      "group": "build",
      "problemMatcher": ["$tsc", "$msCompile"]
    },
    {
      "label": "Build: Website",
      "detail": "Build Angular application",
      "type": "shell",
      "command": "pnpm --filter @stock-charts/client run build",
      "group": "build",
      "problemMatcher": "$tsc",
      "dependsOn": "Install: Packages (pnpm)",
      "dependsOrder": "sequence"
    },
    {
      "label": "Build: Backend .NET (non-incremental)",
      "detail": "Build .NET solution",
      "type": "shell",
      "command": "dotnet build Charts.sln -v minimal --nologo --no-incremental",
      "group": "build",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Build: Backend .NET (incremental)",
      "detail": "Build .NET solution",
      "type": "shell",
      "command": "dotnet build Charts.sln -v minimal --nologo",
      "group": "build",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Build: Backend .NET (production)",
      "detail": "Build .NET solution in Release configuration",
      "type": "shell",
      "command": "dotnet build Charts.sln -c Release -v minimal --nologo",
      "group": "build",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Lint: All (check)",
      "detail": "Run all linting and formatting checks (ESLint, Prettier, Roslynator, dotnet format, markdownlint, stylelint)",
      "dependsOn": [
        "Lint: Website (check)",
        "Lint: Backend .NET (check)",
        "Lint: Markdown (check)",
        "Lint: Stylelint (check)"
      ],
      "dependsOrder": "parallel",
      "group": "test",
      "problemMatcher": "$markdownlint"
    },
    {
      "label": "Lint: All (fix)",
      "detail": "Auto-fix all linting and formatting (ESLint, Prettier, Roslynator, dotnet format, markdownlint)",
      "dependsOn": ["Lint: All code (fix)", "Lint: Markdown (fix)"],
      "dependsOrder": "sequence",
      "group": "none",
      "problemMatcher": "$markdownlint"
    },
    {
      "label": "Lint: All code (fix)",
      "detail": "Auto-fix Website (ESLint + Prettier), Backend (Roslynator + dotnet format), and CSS (stylelint) code",
      "dependsOn": [
        "Lint: Website (fix)",
        "Lint: Backend .NET (fix)",
        "Lint: Stylelint (fix)"
      ],
      "dependsOrder": "parallel",
      "group": "none",
      "problemMatcher": ["$tsc", "$markdownlint"]
    },
    {
      "label": "Lint: Website (check)",
      "detail": "Check Angular, library, and VitePress code with ESLint and Prettier",
      "type": "shell",
      "command": "bash scripts/website-lint.sh check",
      "group": "test",
      "problemMatcher": "$eslint-stylish"
    },
    {
      "label": "Lint: Website (fix)",
      "detail": "Auto-fix Angular, library, and VitePress code with ESLint and format with Prettier",
      "type": "shell",
      "command": "bash scripts/website-lint.sh fix",
      "group": "none",
      "problemMatcher": "$tsc"
    },
    {
      "label": "Lint: Backend .NET (check)",
      "detail": "Check .NET code formatting with dotnet format (Roslynator optional)",
      "type": "shell",
      "command": "bash scripts/dotnet-lint.sh check",
      "dependsOn": ["Build: Backend .NET (incremental)"],
      "dependsOrder": "sequence",
      "group": "test",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Lint: Backend .NET (fix)",
      "detail": "Format Backend .NET with dotnet format (Roslynator optional)",
      "type": "shell",
      "command": "bash scripts/dotnet-lint.sh fix",
      "group": "none",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Lint: Markdown (check)",
      "detail": "Lint markdown files",
      "type": "shell",
      "command": "pnpm run lint:md",
      "group": "test",
      "problemMatcher": "$markdownlint"
    },
    {
      "label": "Lint: Markdown (fix)",
      "detail": "Auto-fix markdown formatting issues",
      "type": "shell",
      "command": "pnpm run lint:md:fix",
      "group": "none",
      "problemMatcher": "$markdownlint"
    },
    {
      "label": "Lint: Stylelint (check)",
      "detail": "Check CSS files with stylelint",
      "type": "shell",
      "command": "pnpm run lint:css",
      "group": "test"
    },
    {
      "label": "Lint: Stylelint (fix)",
      "detail": "Auto-fix CSS files with stylelint",
      "type": "shell",
      "command": "pnpm run lint:css:fix",
      "group": "none"
    },
    {
      "label": "Test: All tests",
      "detail": "Run Website and Backend .NET unit tests",
      "dependsOn": ["Test: Website", "Test: Backend .NET"],
      "dependsOrder": "parallel",
      "group": "test",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Test: Website",
      "detail": "Run Angular unit tests",
      "type": "shell",
      "command": "pnpm --filter @stock-charts/client run test",
      "group": "test",
      "problemMatcher": "$tsc"
    },
    {
      "label": "Test: Backend .NET",
      "detail": "Run .NET unit tests",
      "type": "shell",
      "command": "pnpm run test:dotnet",
      "group": "test",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Review: CodeRabbit CLI (plain)",
      "detail": "Perform a full code review with CodeRabbit CLI in plain text response mode",
      "type": "shell",
      "command": "coderabbit",
      "args": ["--plain"]
    },
    {
      "label": "Review: CodeRabbit CLI (prompt-only)",
      "detail": "Perform a full code review with CodeRabbit CLI in prompt-only response mode",
      "type": "shell",
      "command": "coderabbit",
      "args": ["--prompt-only"]
    },
    {
      "label": "Review: CodeRabbit CLI (uncommitted, plain)",
      "detail": "Perform a code review on uncommitted with CodeRabbit CLI in plain text response mode",
      "type": "shell",
      "command": "coderabbit",
      "args": ["--plain", "--type", "uncommitted"]
    },
    {
      "label": "Review: CodeRabbit CLI (uncommitted, prompt-only)",
      "detail": "Perform a code review on uncommitted with CodeRabbit CLI in prompt-only response mode",
      "type": "shell",
      "command": "coderabbit",
      "args": ["--prompt-only", "--type", "uncommitted"]
    },
    {
      "label": "Run: Full development stack",
      "detail": "Start all Backend .NET services and Website dev server",
      "dependsOn": [
        "Stop: All services",
        "Run: Azure Storage",
        "Run: Azure Functions",
        "Run: Web API",
        "Run: Website dev server"
      ],
      "dependsOrder": "sequence"
    },
    {
      "label": "Run: Azure Storage",
      "detail": "Start Azurite (Azure Storage Emulator)",
      "type": "shell",
      "command": "pnpm run azure:start",
      "isBackground": true,
      "problemMatcher": {
        "owner": "azure-storage",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^Azurite .* service is starting",
          "endsPattern": "^Azurite .* successfully listening"
        }
      },
      "presentation": {
        "clear": true
      }
    },
    {
      "label": "Run: Azure Functions",
      "detail": "Start Azure Functions host",
      "type": "shell",
      "command": "node scripts/start-functions.js",
      "dependsOn": "Build: Backend .NET (incremental)",
      "dependsOrder": "sequence",
      "isBackground": true,
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "problemMatcher": {
        "owner": "azure-functions",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*Azure Functions",
          "endsPattern": "^.*Worker process started"
        }
      }
    },
    {
      "label": "Run: Web API",
      "detail": "Start ASP.NET Core Web API server",
      "type": "shell",
      "command": "dotnet run",
      "options": {
        "cwd": "${workspaceFolder}/server/WebApi"
      },
      "isBackground": true,
      "group": "none",
      "problemMatcher": {
        "owner": "web-api",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*Building",
          "endsPattern": "^.*Application started"
        }
      }
    },
    {
      "label": "Run: Website dev server",
      "detail": "Start Angular development server (with HMR)",
      "type": "shell",
      "command": "pnpm --filter @stock-charts/client run start",
      "isBackground": true,
      "group": "none",
      "problemMatcher": {
        "owner": "website",
        "pattern": { "regexp": "^$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*Compiling",
          "endsPattern": "^.*Application bundle generation complete"
        }
      }
    },
    {
      "label": "Stop: Backend services",
      "detail": "Stop backend services (Azure Functions + Web API)",
      "type": "shell",
      "command": "pnpm",
      "args": ["run", "stop:services"],
      "presentation": {
        "clear": true,
        "reveal": "always"
      },
      "group": "none"
    },
    {
      "label": "Stop: Azurite",
      "detail": "Stop Azurite storage emulator (cross-platform)",
      "type": "shell",
      "command": "npx",
      "args": ["kill-port", "10000", "10001", "10002"],
      "presentation": {
        "clear": false,
        "reveal": "silent"
      },
      "group": "none"
    },
    {
      "label": "Stop: Website dev server",
      "detail": "Stop the Angular dev server (attempts to free default port 4200)",
      "type": "shell",
      "command": "npx",
      "args": ["kill-port", "4200"],
      "presentation": {
        "clear": true,
        "reveal": "always"
      },
      "group": "none"
    },
    {
      "label": "Stop: All services",
      "detail": "Gracefully stop all running Backend and Website services (cross-platform)",
      "dependsOn": [
        "Stop: Azurite",
        "Stop: Backend services",
        "Stop: Website dev server"
      ],
      "dependsOrder": "sequence",
      "group": "none",
      "presentation": {
        "clear": true,
        "reveal": "always"
      }
    },

    // =========================================================================
    // CLEANUP
    // =========================================================================
    {
      "label": "Clean: All (hard reset)",
      "detail": "Hard reset: composite of all clean tasks (deep clean)",
      "dependsOn": [
        "Clean: Backend .NET (hard reset)",
        "Clean: Website",
        "Clean: Root and Azure storage"
      ],
      "dependsOrder": "sequence",
      "group": "build"
    },
    {
      "label": "Clean: Website",
      "detail": "Clean Angular build outputs (dist, coverage)",
      "type": "shell",
      "command": "pnpm --filter @stock-charts/client run clean"
    },
    {
      "label": "Clean: Backend .NET",
      "detail": "Clean .NET build outputs (bin, obj)",
      "type": "shell",
      "command": "dotnet clean Charts.sln -v minimal --nologo",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Clean: Backend .NET (hard reset)",
      "detail": "Deletes all bin/obj folders and runs dotnet clean command (hard clean)",
      "type": "shell",
      "command": "bash scripts/dotnet-clean.sh",
      "group": "build",
      "problemMatcher": "$msCompile"
    },
    {
      "label": "Clean: Root and Azure storage",
      "detail": "Clean Azurite and root level items, including npm packages",
      "type": "shell",
      "command": "pnpm run clean"
    },
    {
      "label": "Clean: Azure Storage Emulator data",
      "detail": "Delete local Azurite data and state",
      "type": "shell",
      "command": "pnpm run azure:clean"
    },
    {
      "label": "Delete: Claude temporary files",
      "detail": "Delete all tmpclaude-*-cwd files (bug workaround)",
      "type": "shell",
      "command": "find . -maxdepth 25 -type f -name 'tmpclaude-*-cwd' -delete",
      "options": {
        "shell": {
          "executable": "/bin/bash",
          "args": ["-lc"]
        }
      }
    }
  ]
}
