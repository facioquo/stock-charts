{
  "name": "@facioquo/indy-charts",
  "version": "0.7.0",
  "description": "Framework-agnostic financial charting library with technical indicators and stock market data visualization",
  "author": "facioquo",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/facioquo/stock-charts.git",
    "directory": "libs/indy-charts"
  },
  "readme": "README.md",
  "homepage": "https://github.com/facioquo/stock-charts/tree/main/libs/indy-charts#readme",
  "bugs": {
    "url": "https://github.com/facioquo/stock-charts/issues"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "restricted"
  },
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./vue": {
      "types": "./dist/vue/index.d.ts",
      "import": "./dist/vue/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "prebuild": "pnpm --filter @facioquo/chartjs-chart-financial run build",
    "build": "tsup",
    "prelint": "pnpm --filter @facioquo/chartjs-chart-financial run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write \"**/*.{ts,json}\"",
    "format:check": "prettier --check \"**/*.{ts,json}\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix"
  },
  "dependencies": {
    "chartjs-adapter-date-fns": "^3.0.0",
    "date-fns": "^4.4.0"
  },
  "peerDependencies": {
    "chart.js": "^4.5.1",
    "chartjs-plugin-annotation": "^3.1.0",
    "vue": "^3.5.0"
  },
  "peerDependenciesMeta": {
    "vue": {
      "optional": true
    }
  },
  "devDependencies": {
    "@facioquo/chartjs-chart-financial": "workspace:*",
    "@eslint/js": "^10.0.1",
    "@vitest/eslint-plugin": "^1.6.20",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "jiti": "^2.7.0",
    "typescript-eslint": "^8.61.1",
    "tsup": "^8.5.1",
    "vitest": "^4.1.9",
    "vue": "3.5.38"
  }
}
