{
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": ".",
    "declaration": true,
    // rollup-plugin-dts (used by tsup for DTS bundling) injects baseUrl:"." programmatically,
    // which TypeScript 6 treats as TS5101. Remove when rollup-plugin-dts is updated.
    "ignoreDeprecations": "6.0",
    "declarationMap": true,
    "sourceMap": true,
    "module": "ES2020",
    "target": "ES2020",
    "lib": ["ES2020", "DOM"],
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "types": []
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist", "**/*.spec.ts", "eslint.config.ts", "tsup.config.ts", "vitest.config.ts"]
}
